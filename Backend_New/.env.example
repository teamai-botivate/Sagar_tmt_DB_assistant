# =============================================================================
# DB Assistant Backend Configuration
# Single Database, Multi-Domain Architecture
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
MODEL_NAME=gpt-4o-mini

# -----------------------------------------------------------------------------
# DATABASE CONNECTION (SINGLE DATABASE)
# -----------------------------------------------------------------------------
# All domains (HR, Sales, Maintenance) connect to the SAME database.
# Domain isolation is handled by ALLOWED_TABLES per domain.

# Option 1: Full URL (Recommended)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Option 2: Individual components (fallback if DATABASE_URL not set)
DB_HOST=your-db-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# Legacy aliases (for backward compatibility - all point to same DB)
# DB_CHECKLIST_URL - uses DATABASE_URL
# DB_LEAD_TO_ORDER_URL - uses DATABASE_URL  
# DB_SAGAR_URL - uses DATABASE_URL

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# DOMAIN ARCHITECTURE
# -----------------------------------------------------------------------------
# This system has ONE database with THREE domains:
#
# 1. HR Operations (checklist domain):
#    - Tables: users, checklist, delegation, leave_request, visitors, etc.
#    - Use for: employee tasks, leaves, HR queries
#
# 2. Sales CRM (lead_to_order domain):
#    - Tables: fms_leads, enquiry_to_order, make_quotation, login
#    - Use for: leads, sales pipeline, quotations
#
# 3. Maintenance (sagar_db domain):
#    - Tables: maintenance_task_assign
#    - Use for: machine repairs, maintenance tasks
#
# The router automatically determines which domain handles each query.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# NOTE: SECURITY SETTINGS ARE HARDCODED
# The following are hardcoded in app/core/security.py:
#   - MAX_QUERY_LENGTH = 50000
#   - ALLOWED_TABLES (per domain)
#   - BLOCKED_KEYWORDS (DROP, DELETE, UPDATE, etc.)
#   - BLOCKED_PATTERNS (SQL injection, file ops, etc.)
# This prevents bypass attempts via environment variable manipulation.
# -----------------------------------------------------------------------------
